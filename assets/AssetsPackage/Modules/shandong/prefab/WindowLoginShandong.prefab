    \ \u9002\u5EA6\u6E38\u620F\u76CA\u8111 \u6C89\u8FF7\u6E38\u620F\u4F24\u8EAB \u5408\u7406\u5B89\u6392\u65F6\u95F4
    \u4EAB\u53D7\u5065\u5EB7\u751F\u6D3B\n\u6279\u51C6\u6587\u53F7\uFF1A\u65B0\u5E7F\u51FA\u5BA1\uFF082017\uFF094971\u53F7
    ISBN:978-7-7979-8321-1 \u5DDD\u7F51\u6587 \uFF082017\uFF096576-278\u53F7 ICP\uFF1A\u5DDDB2-20180092
    \ \u65B0\u51FA\u7F51\u8BC1\uFF1A\uFF08\u5DDD\uFF092259836\u53F7 \u8F6F\u8457\u6743\u4EBA\uFF1A\u56DB\u5DDD\u5C11\u8F69\u7F51\u7EDC\u79D1\u6280\u6709\u9650\u516C\u53F8"
