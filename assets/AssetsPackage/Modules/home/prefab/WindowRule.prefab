--- !u!114 &114654623056181876
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_PrefabParentObject: {fileID: 0}
  m_PrefabInternal: {fileID: 100100000}
  m_GameObject: {fileID: 1592039218327322}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 708705254, guid: f70555f144d8491a825f0804e09c671c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.2784314, g: 0.20392157, b: 0.03137255, a: 1}
  m_RaycastTarget: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
    m_TypeName: UnityEngine.UI.MaskableGraphic+CullStateChangedEvent, UnityEngine.UI,
      Version=1.0.0.0, Culture=neutral, PublicKeyToken=null
  m_FontData:
    m_Font: {fileID: 12800000, guid: 1c6e629e04864b442b3f14074b69fbb4, type: 3}
    m_FontSize: 25
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\u3010\u7528\u724C\u3011\r\n1.\t\u53EA\u6709\u7B52\u3001\u6761\u3001\u4E073\u79CD\u82B1\u8272,\u5171108\u5F20\u724C\u3002\r\n\u3010\u80E1\u724C\u3011\r\n1.\u5FC5\u987B\u8981\u6253\u7F3A(\u6253\u6389\u4E00\u79CD\u82B1\u8272)\u4E4B\u540E\u624D\u80FD\u80E1\u724C,\u5373\u80E1\u724C\u65F6\u4E0D\u80FD\u6709\u4E09\u79CD\u82B1\u8272,\u5426\u5219\u4E3A\u82B1\u732A\u3002\r\n2.\u8FC7\u624B\u80E1(\u8FC7\u6C34\u4E0D\u80E1):\u5982\u679C\u67D0\u4E00\u56DE\u5408\u4E2D,\u6709\u4EBA\u70B9\u70AE,\u8BE5\u73A9\u5BB6\u5728\u7B2C\u4E00\u6B21\u6CA1\u6709\u80E1,\u5219\u5176\u4ED6\u73A9\u5BB6\u5728\u8BE5\u56DE\u5408\u4E2D\u518D\u6B21\u70B9\u70AE\u65F6,\u53EA\u8981\u6CA1\u6709\u52A0\u756A\u8BE5\u73A9\u5BB6\u5C31\u4E0D\u80FD\u80E1(\u81EA\u6478\u9664\u5916)\u3002\u5F53\u8BE5\u73A9\u5BB6\u6709\u52A8\u724C(\u5373\u78B0\u3001\u6760\u3001\u6478\u724C)\u540E,\u8BE5\u56DE\u5408\u8FC7\u624B\u80E1\u9650\u5236\u89E3\u9664\u3002\r\n\u3010\u6E38\u620F\u672F\u8BED\u3011\r\n1\u98D8:\u724C\u5C40\u5F00\u59CB\u524D\u73A9\u5BB6\u9009\u62E9\u201C\u98D8\u201D\u6216\u201C\u4E0D\u98D8\u201D\u6765\u51B3\u5B9A\u52A0\u500D\u4E0E\u5426\u3002\r\n2\u672C\u91D1:\u724C\u5C40\u5F00\u59CB\u65F6,\u5E84\u5BB6\u5728\u5C3E\u5BB6\u6478\u5B8C\u724C\u540E,\u5C06\u63A5\u4E0B\u6765\u7684\u90A3\u5F20\u724C\u7FFB\u5F00,\u7FFB\u51FA\u7684\u8FD9\u5F20\u724C\u53EB\u672C\u91D1\u3002\r\n3\u542C\u7528:\u672C\u91D1\u7684\u524D\u540E\u4E24\u5F20\u724C\u79F0\u4E3A\u201C\u542C\u7528\u201D,\u542C\u7528\u724C\u53EF\u4EE5\u4EE3\u66FF\u5176\u4ED6\u4EFB\u610F\u724C\u3002\r\n4.\u98DE:\u542C\u7528\u724C\u53EF\u4EE5\u4EE3\u66FF\u5176\u4ED6\u724C\u8FDB\u884C\u78B0\u7684\u64CD\u4F5C,\u79F0\u4E3A\u201C\u98DE\u201D\u3002\r\n5\u63D0:\u201C\u98DE\u201D\u724C\u540E,\u82E5\u6478\u5230\u78B0\u724C\u4E2D\u7684\u975E\u542C\u7528\u724C,\u5219\u53EF\u8FDB\u884C\u201C\u63D0\u201D\u7684\u64CD\u4F5C\uFF0C\u7528\u6478\u5230\u7684\u724C\u628A\u542C\u7528\u724C\u63D0\u51FA\u6765\u3002\r\n6\u6839:\u56DB\u5F20\u76F8\u540C\u7684\u724C\u4E0D\u6760\u51FA\u6765,\u4E3A\u4E00\u6839\u3002\r\n7.\u8840\u6218:\u6307\u4E00\u5BB6\u80E1\u724C\u540E\u4E0D\u7ED3\u675F,\u672A\u80E1\u724C\u7684\u73A9\u5BB6\u7EE7\u7EED\u6253,\u76F4\u5230\u6709\u4E09\u5BB6\u80E1\u6216\u4F59\u4E0B\u7684\u73A9\u5BB6\u6D41\u5C40\u3002\r\n8\u67E5\u5927\u53EB:\u6D41\u5C40\u65F6,\u68C0\u67E5\u73A9\u5BB6\u662F\u5426\u4E0B\u53EB,\u672A\u4E0B\u53EB\u7684\u73A9\u5BB6(\u82B1\u732A\u9664\u5916)\u8981\u8D54\u4ED8\u5DF2\u4E0B\u53EB\u7684\u73A9\u5BB6\u6700\u5927\u53EF\u80FD\u756A\u3002\r\n\u3010\u80E1\u724C\u7C7B\u578B\u3011\r\n1\u5E73\u80E1(1\u756A):\u56DB\u574E\u724C\u52A0\u4E00\u5BF9\u5C06\u3002\r\n2\u5BF9\u5BF9\u80E1(3\u756A):\u56DB\u526F\u523B\u5B50\u52A0\u4E00\u5BF9\u5C06\u3002\r\n3\u6E05\u4E00\u8272(3\u756A):\u5168\u90E8\u662F\u4E00\u79CD\u82B1\u8272\u7684\u5E73\u80E1\u3002\r\n4\u4E03\u5BF9(3\u756A):\u73A9\u5BB6\u624B\u724C\u90FD\u662F\u4E24\u5F20\u4E00\u5BF9\u7684,\u6CA1\u6709\u78B0\u548C\u6760\u3002\r\n5\u9F99\u4E03\u5BF9(4\u756A):\u724C\u578B\u4E3A\u4E03\u5BF9,\u4F46\u73A9\u5BB6\u624B\u4E2D\u6709\u56DB\u5F20\u4E00\u6837\u7684\u724C(\u6CA1\u6709\u6760\u51FA)\u3002\r\n6\u6E05\u5BF9(6\u756A):\u6E05\u4E00\u8272+\u5BF9\u5BF9\u80E1\u3002\r\n7\u6E05\u4E03\u5BF9(6\u756A):\u6E05\u4E00\u8272+\u4E03\u5BF9\u3002\r\n8\u6E05\u9F99\u4E03\u5BF9(7\u756A):\u6E05\u4E00\u8272+\u9F99\u4E03\u5BF9\u3002\r\n\u3010\u53E6\u52A0\u756A\u3011\r\n\u3010\u6839\u3011:+1\u756A,\u6709\u56DB\u5F20\u4E00\u6837\u7684\u724C,\u4E0D\u6760\u51FA\u6765\u3002\r\n\u3010\u6760\u3011:+1\u756A,\u6760\u51FA\u540E\u7684\u724C\u3002\r\n\u3010\u6760\u4E0A\u82B1\u3011:+1\u756A,\u73A9\u5BB6\u6760\u724C\u540E,\u8865\u7684\u724C\u6021\u597D\u80E1\u724C\u3002\r\n\u3010\u6760\u4E0A\u70AE\u3011:+1\u756A,\u73A9\u5BB6\u6760\u724C\u540E,\u8865\u724C\u540E\u6253\u51FA\u4E00\u5F20\u724C,\u6253\u51FA\u7684\u724C\u88AB\u5176\u4ED6\u73A9\u5BB6\u80E1\u724C,\u80E1\u724C\u7684\u4EBA\u52A01\u756A\u3002\r\n\u3010\u62A2\u6760\u80E1\u3011:+1\u756A,\u73A9\u5BB6\u9762\u4E0B\u6760\u65F6,\u5176\u4ED6\u73A9\u5BB6\u53EF\u4EE5\u62A2\u6760\u80E1\u3002\r\n\u3010\u91D1\u94A9\u9493\u3011:+1\u756A,\u5728\u3010\u5BF9\u5BF9\u80E1\u3011\u4E00\u7C7B\u7684\u724C\u578B\u4E2D,\u4E0B\u53EB\u7684\u724C\u4E3A\u5C06\u724C,\u4E14\u5176\u4F59\u724C\u5DF2\u7ECF\u78B0\u3001\u6760\u51FA,\u6B64\u65F6\u80E1\u724C\u3002\r\n\u3010\u91D1\u94A9\u70AE\u3011:+1\u756A,\u5728\u3010\u5BF9\u5BF9\u80E1\u3011\u4E00\u7C7B\u7684\u724C\u578B\u4E2D,\u4E0B\u53EB\u7684\u724C\u4E3A\u5C06\u724C,\u4E14\u5176\u4F59\u724C\u5DF2\u7ECF\u78B0\u3001\u6760\u51FA,\u6B64\u65F6\u70B9\u70AE,\u80E1\u724C\u7684\u4EBA\u52A01\u756A\u3002\r\n\u3010\u65E0\u542C\u7528\u3011:+2\u756A,\u80E1\u724C\u65F6,\u724C\u4E2D\u65E0\u542C\u7528\u3002\r\n\u3010\u672C\u91D1\u3011:+1\u756A,\u73A9\u5BB6\u624B\u4E2D\u67093\u5F20\u672C\u91D1\u6216\u4E0E\u542C\u7528\u7EC4\u62103\u5F20\u672C\u91D1\u7684\u7EC4\u5408\u3002\r\n\u3010\u63A5\u672C\u91D1\u3011:+1\u756A,\u5728\u3010\u672C\u91D1\u3011\u7684\u57FA\u7840\u4E0A,\u73A9\u5BB6\u624B\u4E2D\u7684\u672C\u91D1\u4E0E\u542C\u7528\u7EC4\u62104\u5F20\u672C\u91D1\u7684\u7EC4\u5408,\u4E0D\u53E6\u52A0\u6839\u7684\u756A\u6570\u3002\r\n\u3010\u5929\u80E1\u3011:+1\u756A,\u5E84\u5BB6\u53D1\u5B8C\u724C\u4EE5\u540E\u80E1\u724C\u3002\r\n\u3010\u5730\u80E1\u3011:+1\u756A,\u95F2\u5BB6\u539F\u624B\u724C\u5373\u4E0B\u53EB,\u5E84\u5BB6\u6253\u51FA\u4E00\u5F20\u724C\u540E\u70B9\u70AE,\u8BE5\u95F2\u5BB6\u80E1\u724C\r\n\u3010\u80E1\u724C\u8BF4\u660E\u3011\r\n1\u57FA\u672C\u8F93(\u5B34)=\u5E95\u91D1*\u500D\u6570,\u4E00\u70AE\u591A\u54CD\u6309\u73A9\u5BB6\u5404\u81EA\u4E00\u5BF9\u4E00\u8BA1\u7B97\u91D1\u5E01\u3002\u5982\u679C\u7ED3\u7B97\u5176\u4E2D\u4E00\u65B9\u98D8,\u4E3A\u5E95\u91D1*\u500D\u6570*2;\u82E5\u4E24\u65B9\u90FD\u98D8\u98CE,\u4E3A\u5E95\u91D1*\u500D\u6570*4\u3002\u70B9\u70AE\u6536\u53D6\u70B9\u70AE\u73A9\u5BB6\u7684\u79EF\u5206(\u4E00\u70AE\u591A\u54CD\u4E00\u5BF9\u4E00\u7ED3\u7B97);\u81EA\u6478\u6536\u53D6\u672A\u80E1\u724C\u73A9\u5BB6\u79EF\u5206\u3002\r\n"
