--- !u!114 &114435192307644832
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_PrefabParentObject: {fileID: 0}
  m_PrefabInternal: {fileID: 100100000}
  m_GameObject: {fileID: 1313369791573728}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 708705254, guid: f70555f144d8491a825f0804e09c671c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.2784314, g: 0.20392157, b: 0.03137255, a: 1}
  m_RaycastTarget: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
    m_TypeName: UnityEngine.UI.MaskableGraphic+CullStateChangedEvent, UnityEngine.UI,
      Version=1.0.0.0, Culture=neutral, PublicKeyToken=null
  m_FontData:
    m_Font: {fileID: 12800000, guid: 1c6e629e04864b442b3f14074b69fbb4, type: 3}
    m_FontSize: 25
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\u3010\u7528\u724C\u3011\r\n2\u5230A\uFF0C\u5171\u8BA152\u5F20\u724C\u3002\r\n9\u5230A\uFF0C\u5171\u8BA124\u5F20\u724C\u3002\r\n\r\n\u3010\u57FA\u672C\u89C4\u5219\u3011\r\n1.\u3010\u8C79\u5B50\u3011\u4E09\u5F20\u4E00\u6837\u70B9\u6570\u7684\u724C\r\n2.\u3010\u6E05\u4E00\u8272\u62D6\u62C9\u673A\u3011\u540C\u4E00\u82B1\u8272\u7684\u987A\u5B50\r\n3.\u3010\u6E05\u4E00\u8272\u3011\u540C\u4E00\u82B1\u8272\r\n4.\u3010\u62D6\u62C9\u673A\u3011\u82B1\u8272\u4E0D\u4E00\u6837\u7684\u987A\u5B50\r\n5.\u3010\u5BF9\u5B50\u3011\u5982\u9ED1\u6843Q+\u6885\u82B1Q+\u65B9\u5757A\r\n6.\u3010\u5355\u5F20\u3011\u5982\u9ED1\u6843Q+\u9ED1\u6843A+\u7EA2\u6843J\r\n\r\n\u3010\u724C\u578B\u5927\u5C0F\u3011\r\n1.\u3010\u6E05\u4E00\u8272\u5927\u3011\u8C79\u5B50>\u6E05\u4E00\u8272\u62D6\u62C9\u673A>\u6E05\u4E00\u8272>\u62D6\u62C9\u673A>\u5BF9\u5B50>\u5355\u5F20\r\n2.\u3010\u987A\u5B50\u5927\u3011\u8C79\u5B50>\u6E05\u4E00\u8272\u62D6\u62C9\u673A>\u62D6\u62C9\u673A>\u6E05\u4E00\u8272>\u5BF9\u5B50>\u5355\u5F20\r\n3.\u5F53\u724C\u578B\u3001\u70B9\u6570\u4E00\u6837\u662F\uFF0C\u6BD4\u70B9\u6570\u6700\u5927\u4E00\u5F20\u724C\u7684\u82B1\u8272;\u9ED1\u6843\uFF1E\u7EA2\u6843\uFF1E\u6A31\u82B1\uFF1E\u65B9\u5757\n4.
    235\u6740\u8C79\u5B50\n\r\n\u3010\u4E0B\u6CE8\u89C4\u5219\u3011\r\n1.\u3010\u4E0B\u5E95\u6CE8\u3011\u5F00\u5C40\u65F6\uFF0C\u6BCF\u4EBA\u4E0B\u4E00\u4EFD\u5E95\u6CE8\u3002\r\n2.\u3010\u8DDF\u6CE8\u3011\u8DDF\u7740\u4E0A\u4E00\u5BB6\u7684\u4E0B\u6CE8\u91D1\u989D\u3002\r\n3.\u3010\u52A0\u6CE8\u3011\u4E0B\u6CE8\u91D1\u989D\u9AD8\u4E8E\u4E0A\u4E00\u5BB6\u4E0B\u6CE8\u7684\u91D1\u989D\u3002\u52A0\u6CE8\u6309\u5E95\u6CE8\u7684\u500D\u6570\u52A0\uFF0C\u6700\u591A5\u500D\u3002\r\n4.\u3010\u5168\u4E0B\u3011\u6839\u636E\u5269\u4F59\u8F6E\u6570\u548C\u5E95\u6CE8\u8BA1\u7B97\u51FA\u5168\u4E0B\u91D1\u989D\uFF0C\u53EA\u6709\u4E24\u4E2A\u4EBA\u65F6\u624D\u53EF\u4EE5\u5168\u4E0B\uFF1B\u53CC\u65B9\u643A\u5E26\u91D1\u989D\u5927\u4E8E\u8BA1\u7B97\u51FA\u7684\u91D1\u989D\u624D\u53EF\u4EE5\u5168\u4E0B\u3002\r\n\r\n\u3010\u6BD4\u724C\u89C4\u5219\u3011\r\n1.\t\u6BD4\u724C\u65F6\uFF0C\u9700\u8981\u4E0B\u4E00\u6CE8\u3002\r\n2.\t\u5269\u4F59\u4EBA\u6570\uFF1E2\u65F6\uFF0C\u53EA\u80FD\u770B\u5F00\u770B\u3001\u95F7\u5F00\u95F7\u3002\r\n3.\t\u5269\u4F59\u4EBA\u6570=2\u65F6\uFF0C\u53EF\u4EE5\u770B\u5F00\u770B\uFF0C\u95F7\u5F00\u770B\uFF0C\u770B\u5F00\u95F7\uFF0C\u95F7\u5F00\u95F7\u3002\r\n4.\t\u5230\u8FBE\u4E0A\u9650\u8F6E\u6570\uFF0815\u8F6E\u6216\u800520\u8F6E\uFF09\uFF0C\u81EA\u52A8\u5F00\u724C\u3002\r\n\r\n\u3010\u5012\u8BA1\u65F6\u89C4\u5219\u3011\r\n1.\t\u5012\u8BA1\u65F6\u521D\u59CB\u662F60\u79D2\u3002\r\n2.\t\u968F\u7740\u7528\u6237\u4E0B\u6CE8\u589E\u52A0\uFF0C\u4F1A\u8FDB\u884C\u9002\u5F53\u8FFD\u52A0\u3002\r\n\u3010\u81EA\u52A8\u6BD4\u724C\u3011\r\n1.\t\u7528\u6237\u56E0\u4E3A\u4E0D\u53EF\u6297\u62D2\u56E0\u7D20\uFF0C\u5728\u5012\u8BA1\u65F6\u7ED3\u675F\u540E\uFF0C\u672A\u8FDB\u884C\u64CD\u4F5C\uFF0C\u5C06\u7531\u7CFB\u7EDF\u81EA\u52A8\u884C\u8FDB\u6BD4\u724C\u3002\r\n2.\t\u7CFB\u7EDF\u6BD4\u724C\u65F6\uFF0C\u4F46\u9006\u65F6\u9488\u987A\u5E8F\u9010\u4E2A\u6BD4\u724C\uFF0C\u53EF\u4EE5\u770B\u5F00\u770B\u3001\u95F7\u5F00\u95F7\u3001\u95F7\u5F00\u770B\u3002\r\n3.\t\u7CFB\u7EDF\u6BD4\u724C\u65F6\uFF0C\u7B2C\u4E00\u6B21\u6BD4\u724C\uFF0C\u9700\u8981\u4E0B\u4E00\u6CE8\uFF1B\u7B2C\u4E8C\u6B21\u6BD4\u724C\uFF0C\u9700\u8981\u4E0B\u4E00\u6CE8\uFF1B\u7B2C\u4E09\u6B21\u4E0D\u9700\u8981\u3002\r\n"
