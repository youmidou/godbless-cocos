--- !u!114 &114237513073541572
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_PrefabParentObject: {fileID: 0}
  m_PrefabInternal: {fileID: 100100000}
  m_GameObject: {fileID: 1424654011984480}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 708705254, guid: f70555f144d8491a825f0804e09c671c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.26666668, g: 0.10980392, b: 0.007843138, a: 1}
  m_RaycastTarget: 0
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
    m_TypeName: UnityEngine.UI.MaskableGraphic+CullStateChangedEvent, UnityEngine.UI,
      Version=1.0.0.0, Culture=neutral, PublicKeyToken=null
  m_FontData:
    m_Font: {fileID: 12800000, guid: 1c6e629e04864b442b3f14074b69fbb4, type: 3}
    m_FontSize: 28
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 300
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1.24
  m_Text: "\u5927\u5385\uFF1A\r\n1\uFF0C\u65B0\u7248\u672C\u7F8E\u672F\u753B\u9762\u5168\u9762\u5347\u7EA7\uFF0C\u589E\u52A0\u84EC\u83B1\u9601\u7EDD\u7248\u76AE\u80A4\uFF0C\u8001\u7528\u6237\u53EF\u83B7\u5F97\uFF0C\u65B0\u76AE\u80A4\u6301\u7EED\u4E0A\u7EBF,\u6E38\u620F\u53F3\u4E0A\u89D2\u8BBE\u7F6E\u53EF\u66F4\u6362\u76AE\u80A4\n2\uFF0C\u65B0\u7248\u672C\u589E\u52A0\u7CBE\u7F8E\u5934\u50CF\u6846\uFF0C\u53EF\u5728\u5927\u5385\u5934\u50CF\u5904\u66F4\u6362\n3\uFF0C\u589E\u52A0\u70B9\u5377\u7F13\u51B2\uFF0C\u73A9\u5BB6\u53EF\u591A\u50A8\u5B58\u70B9\u5377\uFF0C\u907F\u514D\u6E38\u620F\u4E2D\u76F4\u63A5\u5145\u503C\u91D1\u5E01\u9020\u6210\u6258\u7BA1\n4\uFF0C\u65B0\u589E\u667A\u80FD\u5339\u914D\u673A\u5236\uFF0C\u4EE5\u53CAIP\u62A5\u8B66\u706F\uFF0C\u4E3A\u6E38\u620F\u516C\u5E73\u516C\u6B63\u518D\u4E0A\u4E00\u5C42\u697C\n\u62D6\u62C9\u673A\uFF1A\r\n1\uFF0C\u62D6\u62C9\u673A\u66F4\u6539\u5404\u79CD\u72B6\u6001\uFF0C\u8BA9\u770B\u724C\uFF0C\u7B49\u7B49\u72B6\u6001\u66F4\u52A0\u660E\u663E,\u4F18\u5316\u5B57\u4F53\u663E\u793A\n2\uFF0C\u6258\u7BA1\u65F6\u95F4\u6539\u4E3A\u4E24\u79CD\u72B6\u6001\uFF0C\u53EF\u81EA\u52A8PK\u548C\u5F03\u724C\uFF0C\u6839\u636E\u684C\u9762\u60C5\u51B5\u7CFB\u7EDF\u81EA\u52A8\u8BC6\u522B\u3002\u907F\u514D\u73A9\u5BB6\u4E0D\u5FC5\u8981\u5F97\u635F\u5931\n3\uFF0C\u6027\u80FD\u5404\u79CD\u529F\u80FD\u5168\u9762\u5347\u7EA7\u4F18\u5316\uFF0C\u4E3A\u6E38\u620F\u7A33\u5B9A\u4FDD\u9A7E\u62A4\u822A\n4\uFF0C\u516D\u6708\u5F00\u59CB\u6E38\u620F\u8FDB\u5165\u6301\u7EED\u66F4\u65B0\u9636\u6BB5\uFF0C\u65B0\u6E38\u620F\u4E0D\u65AD\u4E0A\u67B6\n5\uFF0C\u4F18\u5316\u8DDF\u6CE8\u7B49\u7B49\u663E\u793A\u6309\u94AE\uFF0C\u6839\u636E\u4EBA\u4F53\u5355\u624B\u6301\u624B\u673A\u6700\u79D1\u5B66\u8BBE\u7F6E\n6\uFF0C\u65B0\u589E\u5404\u79CD\u62D6\u62C9\u673A\u8BED\u97F3\u5305\uFF0C\u6E38\u620F\u8DA3\u5473\u6027\u66F4\u4E0A\u4E00\u5C42\u697C\n"
